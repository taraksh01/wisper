{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wisper",
  "version": "0.1.0",
  "identifier": "com.taraksh01.wisper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wisper",
        "width": 736,
        "height": 640,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "appimage",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBRTM0RUEzOEY5MjkyREYKUldUZmtwS1BvMDdqbXNzL2YxN2dFakZpWHdmeFlrWVRWMmV3cEszUUJnS3FQaFFlVjVQWVJ1SGoK",
      "endpoints": [
        "https://github.com/taraksh01/v3/releases/latest/download/updater.json"
      ]
    }
  }
}
